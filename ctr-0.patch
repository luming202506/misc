+static void parse_custom_csv_file(CPURISCVState *env, const char *filepath)
+{
+   FILE *file = fopen(filepath, "r");
+   if (!file) {
+	error_report("Failed to open custom CSV file: %s", filepath);
+	exit(EXIT_FAILURE);
+   }
+   int capacity = 32;
+   env->csv_data_array = g_new(uint64_t, capacity);
+   env->csv_data_count = 0;
+   env->csv_table = g_hash_table_new_full(g_int64_hash, g_int64_equal, g_free, g_free);
+
+   char line[256];
+   while (fgets(line, sizeof(line), file)) {
+
+	// remove trailing newline
+	size_t len = strlen(line);
+	if (len > 0 && (line[len - 1] == '\n' || line[len -1] =='\r'))
+		line[--len] = '\0';
+
+	char *token = strtok(line, ",");
+	while (token) {
+		uint64_t keyvalue;
+		if (env->csv_data_count >= capacity) {
+			capacity *= 2;
+			env->csv_data_array = g_renew(uint64_t, env->csv_data_array, capacity);
+		}
+		keyvalue = (uint64_t) strtoull(token, NULL, 16);
+		env->csv_data_array[env->csv_data_count] = keyvalue;
+		if (keyvalue == 0)
+			goto nextt;
+		gpointer vv = g_hash_table_lookup(env->csv_table, &keyvalue);
+		if (vv == NULL) {
+			long *key2 = g_new(long, keyvalue);
+			long *value2 = g_new(long, 0);
+			g_hash_table_insert(env->csv_table, key2, value2/*unused*/);
+		}
+nextt:
+		token = strtok(NULL, ",");
+		env->csv_data_count++;
+	}
+   }
+   fclose(file);
+}
+
+static void riscv_cpu_realizefn(DeviceState *dev, Error **errp)
+{
+   RISCVCPU *cpu = RISCV_CPU(dev);
+   CPURISCVState *env = &cpu->env;
+   //Error **local_err = NULL;
+   if (cpu->csv_filepath_cfg) {
+	env->csv_filename = g_strdup(cpu->csv_filepath_cfg);
+	parse_custom_csv_file(env, env->csv_filename);
+   }
+}
